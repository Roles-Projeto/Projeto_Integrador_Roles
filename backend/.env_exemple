NODE_ENV=development

# Banco de dados
# ATENÇÃO: dentro do Docker use DB_HOST=mysql
#          fora do Docker (local sem Docker) use DB_HOST=localhost
DB_HOST=mysql
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=roles_db

# Servidor
PORT=3000

# JWT
JWT_SECRET=

# E-mail (preencher com suas credenciais reais no .env local, nunca aqui)
EMAIL_USER=
EMAIL_PASS=